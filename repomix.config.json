{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "headerText": "Conversation Explorer: summaries plus grounding source for an external improver. The summaries/ directory has per-surface notes across code/UX/data-science lenses; the source files here are the wiring layer, ETL pipeline, and a representative selection of server-fn analysis files that the summaries reference most heavily.",
    "topFilesLength": 10
  },
  "include": [
    "summaries/**/*.md",
    "CLAUDE.md",
    "README.md",
    "REPRODUCE.md",
    "NOTES_DEPLOY.md",
    "NOTES_PHRASES.md",
    "NOTES_CONVERSATIONS.md",
    "NOTES_BASELINE.md",
    "package.json",
    "railpack.json",
    "tsconfig.json",
    "vite.config.ts",
    "app.config.ts",
    "src/router.tsx",
    "src/start.ts",
    "src/lib/**/*.ts",
    "src/routes/__root.tsx",
    "src/routes/auth.tsx",
    "src/routes/index.tsx",
    "src/routes/conversations.tsx",
    "src/server/auth-gate.ts",
    "src/server/queries.ts",
    "src/server/conversation-queries.ts",
    "src/server/phrase-queries.ts",
    "scripts/**/*.ts",
    "scripts/**/*.mjs",
    "scripts/**/*.py",
    "src/server/atlas-queries.ts",
    "src/server/capsule-queries.ts",
    "src/server/comparison-queries.ts",
    "src/server/forecast-queries.ts",
    "src/server/outlier-queries.ts",
    "src/server/counterfactual-queries.ts",
    "src/server/gesture-queries.ts",
    "src/server/turning-point-queries.ts",
    "src/server/recurrence-queries.ts"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "data/**",
      "*.npy",
      "src/styles.css",
      "src/routeTree.gen.ts",
      "repomix-output.xml"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
